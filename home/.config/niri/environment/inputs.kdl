
// в”і
// в”ѓв”Џв”“в”Џв”“в”“в”Џв•‹в”Џ     Inputs
// в”»в”›в”—в”Јв”›в”—в”»в”—в”›     https://github.com/YaLTeR/niri/wiki/Configuration:-Input
//    в”›
input {
    keyboard {
        xkb { layout "us"; variant "altgr-intl"; }
        numlock // numlock on at startup
        repeat-delay 300
        repeat-rate 50
    }

    touchpad {
        off // my touchpad is current broken :"(
        // tap
        // drag true // tap and drag
        natural-scroll
        disabled-on-external-mouse
    }

    mouse {
        accel-speed -0.728     // slower mouse
        accel-profile "flat" // no mouse acceleration
    }

    // don't have one (for now?)
    trackpoint { off; }
    trackball { off; }
    touch { off; }
    tablet { off; map-to-output "eDP-1"; }

    warp-mouse-to-focus mode="center-xy" // warp cursor to the center of newly focused windows.
    focus-follows-mouse max-scroll-amount="0%" // Allow focus-follows-mouse when no scrolling
    // focus-follows-mouse max-scroll-amount="50%" // Allow focus-follows-mouse when only scrolls for half a screen
    // focus-follows-mouse max-scroll-amount="100%" // Allow focus-follows-mouse always
    // workspace-auto-back-and-forth // disabling auto back and forth for now

    //mod-key "Alt"
    disable-power-key-handling
}
